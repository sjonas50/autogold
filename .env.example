# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Database (TimescaleDB + pgvector)
DATABASE_URL=postgresql://gold:gold@localhost:5433/gold_trading

# External APIs
POLYGON_API_KEY=your_polygon_api_key
FRED_API_KEY=your_fred_api_key

# Historical Data Sources (optional — more sources = more backtesting data)
TWELVEDATA_API_KEY=          # Free at https://twelvedata.com — 1+ year of 5m gold data
OANDA_API_KEY=               # Free practice account at https://oanda.com — 6+ months
OANDA_API_URL=https://api-fxpractice.oanda.com

# TradingView Webhook
WEBHOOK_SECRET=your_shared_secret_here

# Trading Parameters
ACCOUNT_SIZE_USD=50000
MAX_RISK_PER_TRADE=0.005
MAX_DRAWDOWN_LIMIT=0.02
MAX_POSITIONS=1
GC_CONTRACT_MULTIPLIER=100
MGC_CONTRACT_MULTIPLIER=10

# FastAPI Webhook Receiver
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
LOG_LEVEL=INFO

# Paperclip
PAPERCLIP_URL=http://localhost:3100
PAPERCLIP_API_KEY=

# Embeddings (OpenAI API — required for text-embedding-3-small)
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
